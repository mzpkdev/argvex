{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "lib/**/*.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "vitest.setup.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules"]
}
